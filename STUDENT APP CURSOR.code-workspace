{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"mcp": {
			"servers": {
				"github": {
					"command": "docker",
					"args": [
						"run",
						"-i",
						"--rm",
						"-e",
						"GITHUB_PERSONAL_ACCESS_TOKEN",
						"ghcr.io/github/github-mcp-server"
					],
					"env": {
						"GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
					},
					"type": "stdio"
				}
			},
			"inputs": [
				{
					"id": "github_token",
					"type": "promptString",
					"description": "GitHub Personal Access Token",
					"password": true
				}
			]
		},
		"files.exclude": {
			"": true
		},
		"search.exclude": {
			"": true
		}
	}
}
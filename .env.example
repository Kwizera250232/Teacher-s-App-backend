PORT=5000
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/studentapp
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
GEMINI_API_KEY=your_google_gemini_api_key_here

# Optional: reject signup when mailbox cannot be verified (SMTP RCPT check)
STRICT_EMAIL_VALIDATE=false
# Leave empty so staff signup uses @schoolname.edu from school name (not staff.umunsi.edu)
STAFF_SIGNUP_EMAIL_DOMAIN=
EXPOSE_RESET_CODE=false
ALLOW_INSECURE_PASSWORD_RESET=false

# Optional SMTP for password-reset emails (otherwise use EXPOSE_RESET_CODE=true in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Real school mailboxes (@schoolslug.mail.umunsi.com) — forward to verified personal email
SCHOOL_MAIL_ENABLED=true
SCHOOL_MAIL_BASE_DOMAIN=mail.umunsi.com
# Mailgun: MX on SCHOOL_MAIL_BASE_DOMAIN, route inbound to POST /api/mail/inbound
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mail.umunsi.com
MAILGUN_WEBHOOK_SIGNING_KEY=
# Dev only: return verification code in API when SMTP is not set
EXPOSE_MAIL_VERIFY_CODE=false

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd student-web && npm ci && VITE_API_URL=https://studentapi.umunsi.com/api npm run build",
  "outputDirectory": "student-web/dist",
  "installCommand": "cd student-web && npm ci",
  "framework": null,
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://studentapi.umunsi.com/app/:path*",
      "permanent": false
    }
  ]
}
